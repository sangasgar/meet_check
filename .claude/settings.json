{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(node -e \"try{const d=JSON.parse(require('fs').readFileSync(0,'utf8'));process.stdout.write((d.tool_input&&d.tool_input.file_path)||'')}catch(e){}\"); [ -n \"$f\" ] && npx prettier --write --ignore-unknown \"$f\" 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Prettier: форматирование файла…"
          }
        ]
      }
    ]
  }
}
