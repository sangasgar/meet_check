generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  meetings     Meeting[]

  @@map("users")
}

model Meeting {
  id          String  @id @default(uuid())
  title       String
  description String?
  ownerId     String
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("meetings")
}
