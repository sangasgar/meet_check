{
  "name": "meet-startap",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run start:dev --workspace api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace web",
    "build:api": "npm run build --workspace api",
    "start:web": "npm run start --workspace web",
    "start:api": "npm run start:prod --workspace api",
    "lint": "npm run lint --workspaces --if-present",
    "lint:web": "npm run lint --workspace web",
    "lint:api": "npm run lint --workspace api",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,mjs,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,mjs,json,css,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
